# ═══════════════════════════════════════════════════════
#  NexusRAG — Environment Configuration
# ═══════════════════════════════════════════════════════

# ── LLM Provider (REQUIRED) ───────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── LLM Settings ──────────────────────────────────────
LLM_MODEL_NAME=gemini-2.5-flash            # Primary model
LLM_FALLBACK_MODELS=gemini-1.5-pro,gemini-1.5-flash
LLM_TEMPERATURE=0.1                        # 0.0=factual, 1.0=creative
LLM_MAX_TOKENS=8192                        # Max response tokens

# ── Embedding Settings ────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                       # cpu | cuda
EMBEDDING_BATCH_SIZE=64

# ── Chunking Settings ─────────────────────────────────
CHUNK_SIZE=1000                            # Target characters per chunk
CHUNK_OVERLAP=200                          # Overlap between chunks
ENABLE_SEMANTIC_CHUNKING=true              # Use semantic breakpoints
ENABLE_CONTEXTUAL_ENRICHMENT=true          # Anthropic-style context prepend

# ── Retrieval Settings ────────────────────────────────
RETRIEVAL_TOP_K=10                         # Chunks to retrieve
SIMILARITY_THRESHOLD=0.3                   # Min relevance score
HYBRID_SEARCH_ALPHA=0.6                    # 0=sparse-only, 1=dense-only
ENABLE_RERANKING=true                      # Cross-encoder re-ranking
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Vector Store Settings ─────────────────────────────
VECTOR_STORE_PATH=data/vector_store        # Persistence directory

# ── API Settings ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_KEY=                                   # Optional: protect API (leave empty to disable)
MAX_UPLOAD_SIZE_MB=100                     # Max file upload size

# ── Performance Settings ──────────────────────────────
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600                     # 1 hour
MAX_CONCURRENT_INGESTIONS=4

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                            # json | console